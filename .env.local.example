# ─────────────────────────────────────────────────────────────────
#  DOMUS — Variáveis de Ambiente (copie para .env.local)
# ─────────────────────────────────────────────────────────────────
#
#  COMO USAR COM GMAIL:
#  1. Acesse: https://myaccount.google.com/security
#  2. Ative a verificação em duas etapas (obrigatório)
#  3. Vá em "Senhas de app" → gere uma senha para "Outro (nome personalizado)"
#  4. Cole a senha de 16 caracteres gerada em SMTP_PASS abaixo
#  5. SMTP_USER deve ser o seu endereço Gmail completo
#
#  NUNCA commite o arquivo .env.local no git.
# ─────────────────────────────────────────────────────────────────

# ── SMTP — Gmail ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# ── Destinatários DOMUS ───────────────────────────────────────────
# E-mail que recebe as inscrições do teste beta
DOMUS_BETA_EMAIL=seu_email@gmail.com

# E-mail que recebe os feedbacks de uso
DOMUS_FEEDBACK_EMAIL=seu_email@gmail.com
